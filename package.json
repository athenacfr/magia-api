{
  "name": "magia-api",
  "version": "0.1.0",
  "description": "Zero-ceremony typed API client generation",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "openapi",
    "codegen",
    "vite",
    "typescript",
    "api-client",
    "tanstack-query",
    "react-query",
    "proxy",
    "rest",
    "webpack",
    "rollup",
    "esbuild",
    "graphql"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/athenacfr/magia-api"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.mts",
        "default": "./dist/vite.mjs"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/cli.d.mts",
        "default": "./dist/cli.mjs"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/test.d.mts",
        "default": "./dist/test.mjs"
      }
    },
    "./codegen": {
      "import": {
        "types": "./dist/codegen.d.mts",
        "default": "./dist/codegen.mjs"
      }
    },
    "./rollup": {
      "import": {
        "types": "./dist/rollup.d.mts",
        "default": "./dist/rollup.mjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.mts",
        "default": "./dist/webpack.mjs"
      }
    },
    "./esbuild": {
      "import": {
        "types": "./dist/esbuild.d.mts",
        "default": "./dist/esbuild.mjs"
      }
    }
  },
  "bin": {
    "magia-api": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt src/"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/webpack": "^5.28.5",
    "esbuild": "^0.27.4",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "rollup": "^4.60.0",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.21.4",
    "typescript": "^5.7.0",
    "vite": "^8.0.1",
    "vitest": "^3.0.0",
    "webpack": "^5.105.4"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "esbuild": ">=0.17.0",
    "rollup": ">=3.0.0",
    "vite": ">=5.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "esbuild": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "dependencies": {
    "@graphql-codegen/core": "^5.0.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@hey-api/openapi-ts": "^0.94.4",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "jiti": "^2.6.1",
    "yaml": "^2.8.3"
  }
}
